# .env.example - Kopieren nach .env und mit echten Werten fuellen.
# .env selbst NIEMALS einchecken (siehe .gitignore und Kapitel 4/5 im Buch).

# Telegram-Bot: Token via @BotFather /newbot, Chat-ID via getUpdates
# (Kapitel 11.2, inkl. Listing 11.1a zum Ermitteln der Chat-ID)
TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<TELEGRAM_CHAT_ID>

# LLM-Provider (OpenAI-kompatibel) - siehe Kapitel 9.4 fuer die Beschaffung
LLM_PROVIDER=openai
LLM_API_KEY=<LLM_API_KEY>
LLM_BASE_URL=<LLM_BASE_URL>
LLM_MODEL=<LLM_MODEL>

# ntfy.sh-Topic - frei waehlbar, aber schwer zu erraten waehlen
# (der Topic-Name ist auf dem oeffentlichen Server dein einziges "Passwort")
NTFY_TOPIC=<NTFY_TOPIC>
